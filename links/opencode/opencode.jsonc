{
  "$schema": "https://opencode.ai/config.json",
  "autoshare": false,
  "autoupdate": true,
  "default_agent": "plan",
  "agent": {
    "plan": {
      "model": "github-copilot/claude-opus-4.8",
      "variant": "xhigh",
    },
    "build": {
      "model": "github-copilot/claude-opus-4.8-fast",
      "variant": "medium",
    }
  },
  "plugin": [],
  "instructions": [
    "/home/ian/.config/work/opencode/AGENTS.md"
  ],
  "permission": {
    "bash": {
      "ssh": "ask",
      "az": "ask"
    },
    "external_directory": {
      "/tmp/**": "allow"
    }
  }
}
