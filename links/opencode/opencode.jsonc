{
  "$schema": "https://opencode.ai/config.json",
  "autoshare": false,
  "autoupdate": true,
  "model": "github-copilot/claude-sonnet-4.6",
  "instructions": [
    "/home/ian/.config/work/opencode/AGENTS.md"
  ],
  "mcp": {
    "tmux-mcp": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "tmux-mcp"
      ],
      "enabled": true,
    },
    "context-server": {
      "type": "remote",
      "url": "http://localhost:8080/mcp",
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {file:~/.secrets/context-server-token}"
      },
      "enabled": true,
    },
  },
  "permission": {
    "bash": {
      "ssh": "ask",
      "az": "ask"
    },
    "external_directory": {
      "/tmp/**": "allow"
    }
  }
}
