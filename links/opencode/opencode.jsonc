{
  "$schema": "https://opencode.ai/config.json",
  "autoshare": false,
  "autoupdate": true,
  "default_agent": "plan",
  "agent": {
    "plan": {
      "model": "github-copilot/claude-opus-4.7",
      "variant": "thinking",
    },
    "build": {
      "model": "github-copilot/claude-sonnet-4.6",
    }
  },
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
    "superpowers@git+https://github.com/obra/superpowers.git"
  ],
  "instructions": [
    "/home/ian/.config/work/opencode/AGENTS.md"
  ],
  "mcp": {
    "ado-msazuredev": {
      "type": "local",
      "command": [
        "agency",
        "mcp",
        "ado",
        "--organization",
        "msazuredev"
      ],
      "enabled": false,
    },
    "ado-msazure": {
      "type": "local",
      "command": [
        "agency",
        "mcp",
        "ado",
        "--organization",
        "msazure"
      ],
      "enabled": false,
    },
    "icm": {
      "type": "local",
      "command": [
        "icm-mcp-proxy"
      ],
      "enabled": false,
    },
    "kusto-dev": {
      "type": "local",
      "command": [
        "agency",
        "mcp",
        "kusto",
        "--service-uri",
        "https://ncdev-hub.eastus.kusto.windows.net"
      ],
      "enabled": false,
    },
    "workiq": {
      "type": "local",
      // "command": ["workiq", "mcp"], // Use this if the below doesn't work
      "command": [
        "npx",
        "-y",
        "@microsoft/workiq",
        "mcp"
      ],
      "enabled": false,
    },
  },
  "permission": {
    "bash": {
      "ssh": "ask",
      "az": "ask"
    },
    "external_directory": {
      "/tmp/**": "allow"
    }
  }
}
