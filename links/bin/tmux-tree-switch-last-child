#!/usr/bin/env bash
# tmux-tree-switch-last-child
# Switch to the last-used child for the current root.
#
# Usage:
#   tmux-tree-switch-last-child

set -euo pipefail

if [ -z "${TMUX:-}" ]; then
  echo "Error: tmux is not running" >&2
  exit 1
fi

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
. "$script_dir/tmux-tree-lib"

root_session=$(tmux_tree_root_name)
child_name=$(tmux_tree_last_child_get "$root_session")

if [ -z "$child_name" ]; then
  exit 0
fi

separator=$(tmux_tree_separator)
child_session="${root_session}${separator}${child_name}"

if tmux has-session -t "=$child_session" 2>/dev/null; then
  tmux switch-client -t "=$child_session"
fi
