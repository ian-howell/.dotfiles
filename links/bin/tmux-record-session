#!/usr/bin/env bash
# tmux-record-session: record a session name + timestamp in the history file.
# Called by the tmux client-session-changed hook:
#   set-hook -g client-session-changed 'run-shell "tmux-record-session #{client_session}"'
# Also callable directly: tmux-record-session <session-name>

set -euo pipefail

SESSION="${1:-}"
if [[ -z "$SESSION" ]]; then
  exit 0
fi

HISTORY_FILE="${HOME}/.local/share/tmux/session-history.json"

mkdir -p "$(dirname "$HISTORY_FILE")"

python3 - "$SESSION" "$HISTORY_FILE" <<'EOF'
import sys, json, time, os

session = sys.argv[1]
path    = sys.argv[2]

history = {}
if os.path.exists(path):
    try:
        history = json.loads(open(path).read())
    except Exception:
        history = {}

history[session] = time.time()

tmp = path + ".tmp"
with open(tmp, "w") as f:
    json.dump(history, f, indent=2)
os.replace(tmp, path)
EOF
