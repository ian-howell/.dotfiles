#!/usr/bin/env bash
# tmux-tree-list-roots
# List tmux root sessions (exclude child sessions).
#
# Usage:
#   tmux-tree-list-roots
#
# Environment:
#   TMUX_TREE_SEPARATOR  Child separator (default: " 🌿 ")
#
# Examples:
#   tmux-tree-list-roots

set -euo pipefail

separator="${TMUX_TREE_SEPARATOR:- 🌿 }"

sessions=$(tmux list-sessions -F '#{session_name}' 2>/dev/null || true)

if [ -z "$sessions" ]; then
  exit 0
fi

while IFS= read -r session; do
  if [ -z "$session" ]; then
    continue
  fi

  case "$session" in
    *"$separator"*)
      continue
      ;;
  esac
  printf '%s\n' "$session"
done <<< "$sessions"
