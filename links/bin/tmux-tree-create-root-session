#!/usr/bin/env bash
# tmux-tree-create-root-session
# Create a tmux root session at a directory and jump to it.
# If the session already exists, just jump to it.
#
# Root sessions carry metadata about their root directory and root name.
#
# Usage:
#   tmux-tree-create-root-session <root-name> <root-dir>
#
# Output:
#   <session-name>
#
# Examples:
#   tmux-tree-create-root-session dotfiles ~/.dotfiles

set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  tmux-tree-create-root-session <root-name> <root-dir>

Creates a tmux root session rooted at a directory.
EOF
}

if [ $# -ne 2 ]; then
  usage
  exit 1
fi

root_name="$1"
root_dir="$2"

# root_dir must be an absolute path
if [[ "$root_dir" == ~* ]]; then
  root_dir="${root_dir/#\~/$HOME}"
fi
if [[ "$root_dir" != /* ]]; then
  root_dir="$(pwd)/$root_dir"
fi

if [ ! -d "$root_dir" ]; then
  echo "Error: root directory does not exist: $root_dir" >&2
  exit 1
fi

sanitize_name() {
  local name="$1"
  while [ "${name#.}" != "$name" ]; do
    name="${name#.}"
  done
  name=$(printf '%s' "$name" | tr '.' '_')
  printf '%s' "$name"
}

session_name=$(sanitize_name "$root_name")

if [ -z "$session_name" ]; then
  echo "Error: root session name is empty after sanitizing" >&2
  exit 1
fi

if ! tmux has-session -t "$session_name" 2>/dev/null; then
  tmux new-session -d -s "$session_name" -c "$root_dir"
  tmux set-option -q -t "$session_name" @tree_root_dir "$root_dir"
  tmux set-option -q -t "$session_name" @tree_root_name "$session_name"
fi

if [ -n "${TMUX:-}" ]; then
  # We're already in a tmux session, so switch to the new session.
  tmux switch-client -t "$session_name"
else
  # Not in a tmux session, so attach to the new session.
  tmux attach-session -t "$session_name"
fi
