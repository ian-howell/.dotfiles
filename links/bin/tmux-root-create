#!/usr/bin/env bash
# tmux-root-create
# Create a tmux root session at a directory.
#
# Usage:
#   tmux-root-create <root-name> <root-dir>
#
# Output:
#   <session-name>
#
# Examples:
#   tmux-root-create dotfiles ~/.dotfiles

set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  tmux-root-create <root-name> <root-dir>

Creates a tmux root session rooted at a directory.
EOF
}

if [ $# -ne 2 ]; then
  usage
  exit 1
fi

root_name="$1"
root_dir="$2"

if [ ! -d "$root_dir" ]; then
  echo "Error: root directory does not exist: $root_dir" >&2
  exit 1
fi

sanitize_name() {
  local name="$1"
  while [ "${name#.}" != "$name" ]; do
    name="${name#.}"
  done
  name=$(printf '%s' "$name" | tr '.' '_')
  printf '%s' "$name"
}

session_name=$(sanitize_name "$root_name")

if [ -z "$session_name" ]; then
  echo "Error: root session name is empty after sanitizing" >&2
  exit 1
fi

if ! tmux has-session -t "=$session_name" 2>/dev/null; then
  tmux new-session -d -s "$session_name" -c "$root_dir"
fi

printf '%s\n' "$session_name"
