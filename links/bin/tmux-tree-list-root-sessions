#!/usr/bin/env bash
# tmux-tree-list-root-sessions
# List root and child sessions for a given tmux root.
#
# Usage:
#   tmux-tree-list-root-sessions <root-session>
#
# Output:
#   <session-name>
#
# Environment:
#   TMUX_TREE_SEPARATOR  Child separator (default: " 🌿 ")
#
# Examples:
#   tmux-tree-list-root-sessions dotfiles

set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  tmux-tree-list-root-sessions <root-session>

Lists sessions rooted at a given tmux session.
EOF
}

if [ $# -ne 1 ]; then
  usage
  exit 1
fi

root_session="$1"

separator="${TMUX_TREE_SEPARATOR:- 🌿 }"

if ! tmux has-session -t "$root_session" 2>/dev/null; then
  echo "Error: tmux session not found: $root_session" >&2
  exit 1
fi

target_sessions=$(tmux list-sessions -F '#{session_name}' 2>/dev/null || true)
if [ -z "$target_sessions" ]; then
  exit 0
fi

while IFS= read -r session; do
  if [ -z "$session" ]; then
    continue
  fi

  if [ "$session" = "$root_session" ]; then
    printf '%s\n' "$session"
    continue
  fi

  case "$session" in
    "$root_session""$separator"*)
      printf '%s\n' "$session"
      ;;
  esac
done <<< "$target_sessions"
